{
  "name": "jobcopilot",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/web",
    "apps/server"
  ],
  "scripts": {
    "dev": "node scripts/check-db.mjs && concurrently \"npm run dev --workspace web\" \"npm run dev --workspace server\"",
    "dev:web": "node scripts/check-db.mjs && npm run dev --workspace web",
    "dev:server": "node scripts/check-db.mjs && npm run dev --workspace server",
    "db:up": "bash scripts/db-compose.sh up",
    "db:down": "bash scripts/db-compose.sh down",
    "db:setup": "bash scripts/db-compose.sh setup",
    "setup:db": "npm run db:setup",
    "prisma:generate": "npm run prisma:generate --workspace web",
    "prisma:migrate": "npm run prisma:migrate --workspace web"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bihiya/jobcopilot.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
