generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id                      String                   @id @default(auto()) @map("_id") @db.ObjectId
  email                   String                   @unique
  passwordHash            String?
  emailVerified           DateTime?
  name                    String?
  image                   String?
  createdAt               DateTime                 @default(now())
  profile                 UserProfile?
  jobs                    Job[]
  fetchedJobs             ExternalJob[]
  mappings                Mapping[]
  authSessions            AuthSession[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  accounts                Account[]
  sessions                Session[]
}

model UserProfile {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  userId           String    @unique @db.ObjectId
  phone            String?
  dateOfBirth      DateTime?
  currentLocation  String?
  currentSalary    String?
  expectedSalary   String?
  noticePeriod     String?
  linkedInUrl      String?
  portfolioUrl     String?
  headline         String?
  education        String?
  experience       String?
  skills           Json?
  resumeUrl        String?
  /// e.g. { "sources": ["linkedin","google"], "query": "...", "title": "...", "location": "...", "limit": 10 }
  jobSearchPreferences Json?
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum JobStatus {
  pending
  auth_required
  ready
  applying
  applied
}

model Job {
  id         String             @id @default(auto()) @map("_id") @db.ObjectId
  userId     String             @db.ObjectId
  url        String
  status     JobStatus          @default(pending)
  matchScore Float?
  createdAt  DateTime           @default(now())
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  auditLogs  JobApplyAuditLog[]
}

model JobApplyAuditLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  jobId     String   @db.ObjectId
  userId    String   @db.ObjectId
  step      String
  message   String
  meta      Json?
  createdAt DateTime @default(now())
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([userId, jobId])
}

model ExternalJob {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  source           String
  sourceJobId      String?
  url              String
  title            String
  company          String?
  location         String?
  description      String?
  titleMatched     Boolean  @default(false)
  descriptionMatch Boolean  @default(false)
  score            Float    @default(0)
  query            String?
  userId           String?  @db.ObjectId
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([source, query])
  @@index([titleMatched, descriptionMatch])
  @@unique([source, sourceJobId])
}

model Mapping {
  id              String @id @default(auto()) @map("_id") @db.ObjectId
  userId          String @db.ObjectId
  site            String
  fieldIdentifier String
  mappedTo        String
  confidence      Float
  user            User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, site])
  @@unique([userId, site, fieldIdentifier])
}

model AuthSession {
  id                  String    @id @default(auto()) @map("_id") @db.ObjectId
  userId              String    @db.ObjectId
  site                String
  storageStatePath    String
  isAuthenticated     Boolean   @default(false)
  lastAuthenticatedAt DateTime?
  lastCheckedAt       DateTime  @default(now())
  createdAt           DateTime  @default(now())
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, site])
}

model EmailVerificationToken {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  userId    String    @db.ObjectId
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  userId    String    @db.ObjectId
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// NextAuth email provider tokens; `id` is required for MongoDB collections.
model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
