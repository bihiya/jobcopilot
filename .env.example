# MongoDB Atlas (replace USER, PASSWORD, CLUSTER, DB name). URL-encode special chars in password.
# DATABASE_URL="mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/jobcopilot?retryWrites=true&w=majority"
# Local Docker (`npm run db:up`):
DATABASE_URL="mongodb://localhost:27017/jobcopilot"
GOOGLE_ID=""
GOOGLE_SECRET=""
# Required for sign-in. Generate: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-output-of-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
OPENAI_API_KEY=""
SERVER_URL="http://localhost:4000"
PLAYWRIGHT_HEADLESS="true"
# Optional: credentials login can work with Google disabled.
APP_BASE_URL="http://localhost:3000"

# Public jobs fetch compliance & reliability controls
# Comma-separated allowlist. Example: "linkedin,naukri,instahyre"
PUBLIC_JOB_FETCH_ALLOWED_SOURCES="linkedin"
# Use "false" to deny direct scraping and require official API integration.
PUBLIC_JOB_FETCH_ALLOW_SCRAPING="true"
# Enforce official API integration globally when set to true.
REQUIRE_OFFICIAL_API_ONLY="false"
# Official API endpoint placeholders (if configured, provider can use these first)
LINKEDIN_OFFICIAL_API_URL=""
LINKEDIN_OFFICIAL_API_TOKEN=""
# Simple rotation pools (comma-separated) for public fetch transport
PUBLIC_JOB_FETCH_USER_AGENTS=""
PUBLIC_JOB_FETCH_PROXIES=""
