# Public jobs fetch compliance & reliability controls
# Comma-separated allowlist. Example: "linkedin,naukri,instahyre"
PUBLIC_JOB_FETCH_ALLOWED_SOURCES="linkedin"
# Use "false" to deny direct scraping and require official API integration.
PUBLIC_JOB_FETCH_ALLOW_SCRAPING="true"
# Official API endpoint placeholders (if configured, provider can use these first)
LINKEDIN_OFFICIAL_API_URL=""
LINKEDIN_OFFICIAL_API_TOKEN=""
# Simple rotation pools (comma-separated) for public fetch transport
PUBLIC_JOB_FETCH_USER_AGENTS=""
PUBLIC_JOB_FETCH_PROXIES=""
