DATABASE_URL="postgresql://postgres:postgres@localhost:5432/jobcopilot?schema=public"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"
POSTGRES_DB="jobcopilot"
GOOGLE_ID=""
GOOGLE_SECRET=""
NEXTAUTH_SECRET=""
